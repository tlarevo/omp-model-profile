{
	"type": "module",
	"name": "omp-model-profile",
	"version": "0.1.0",
	"description": "Named model-role profiles for omp — switch your whole Architect/Default/Subtask model set with /model-profile",
	"homepage": "https://github.com/tlarevo/omp-model-profile#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tlarevo/omp-model-profile.git"
	},
	"bugs": {
		"url": "https://github.com/tlarevo/omp-model-profile/issues"
	},
	"author": "tlarevo",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"omp",
		"oh-my-pi",
		"extension",
		"plugin",
		"model",
		"profile"
	],
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"test": "bun test",
		"prepublishOnly": "bun run check"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@oh-my-pi/pi-ai": "^15",
		"@oh-my-pi/pi-coding-agent": "^15",
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "7.0.0-dev.20260527.1"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-ai": ">=15",
		"@oh-my-pi/pi-coding-agent": ">=15"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"main": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"omp": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"files": [
		"src",
		"skills",
		"README.md",
		"CHANGELOG.md"
	]
}
